GENAI_BASE_URL=https://genai-sharedservice-emea.pwc.com
GENAI_API_KEY=your-api-key-here
GENAI_LLM_MODEL=openai.gpt-4o-mini
GENAI_EMBEDDINGS_MODEL=azure.text-embedding-3-large
GENAI_EMBEDDINGS_DIMENSIONS=1536
USE_MOCK_AI=false
HF_AUTH_TOKEN=your-huggingface-token-here

# If HuggingFace is blocked on your network, copy ~/.cache/huggingface/hub/
# from a machine that has the models downloaded, then set:
# HF_HUB_OFFLINE=1
#
# To use a custom cache location:
# HF_HOME=/path/to/huggingface/cache
